# ==================================
# Docker Compose 環境変数
# ==================================

# ホスト側ポート設定（コンテナ内部ポートは固定）
BACKEND_PORT=5000
FRONTEND_PORT=3000
DB_PORT=5432
MAILPIT_SMTP_PORT=1025
MAILPIT_UI_PORT=8025

# ==================================
# PostgreSQL
# ==================================
POSTGRES_DB=taskflow
POSTGRES_USER=taskflow_user
POSTGRES_PASSWORD=taskflow_pass

# ==================================
# ASP.NET Core
# ==================================
ASPNETCORE_ENVIRONMENT=Development

# ==================================
# JWT 設定
# ※ 本番環境では必ず安全なランダム文字列を設定すること
# ==================================
JWT_SECRET_KEY=ThisIsADevelopmentSecretKeyThatShouldBeAtLeast32CharactersLong!
JWT_ISSUER=taskflow-api
JWT_AUDIENCE=taskflow-frontend
JWT_ACCESS_TOKEN_EXPIRATION_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRATION_DAYS=7

# ==================================
# メール設定
# ==================================
EMAIL_FROM_ADDRESS=noreply@taskflow.local
